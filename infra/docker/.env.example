PYTHONPATH=/app
PYTHONUTF8=1
PYTHONIOENCODING=utf-8
TAVERN_APP_NAME=Tavern LiveOS
TAVERN_ENV=docker
TAVERN_LOG_LEVEL=INFO
TAVERN_WORKSPACE_ROOT=/app
TAVERN_STORAGE_BACKEND=file
TAVERN_TTS_PROVIDER=placeholder
TAVERN_MVP_TTS_PROVIDER=cosyvoice_tts
TAVERN_TTS_FALLBACK_PROVIDER=edge_tts
TAVERN_COSYVOICE_BASE_URL=
TAVERN_COSYVOICE_HEALTH_PATH=
TAVERN_COSYVOICE_SPEECH_PATH=/v1/audio/speech
TAVERN_COSYVOICE_MODEL=CosyVoice2-0.5B
TAVERN_COSYVOICE_VOICE=中文女声
TAVERN_COSYVOICE_FORMAT=wav
TAVERN_COSYVOICE_TIMEOUT_SECONDS=120
TAVERN_TTS_OUTPUT_DIR=.working_dir/artifacts/tts
TAVERN_TEXT_IMAGE_MODEL_PROVIDER=OpenAI
TAVERN_TEXT_IMAGE_MODEL=gpt-5.5
TAVERN_TEXT_IMAGE_REVIEW_MODEL=gpt-5.5
TAVERN_TEXT_IMAGE_REASONING_EFFORT=xhigh
TAVERN_OPENAI_BASE_URL=https://mirror.xinshu.ai
TAVERN_OPENAI_WIRE_API=responses
TAVERN_DISABLE_RESPONSE_STORAGE=true
TAVERN_NETWORK_ACCESS=enabled
TAVERN_WINDOWS_WSL_SETUP_ACKNOWLEDGED=true
OPENAI_API_KEY=
TAVERN_OPENAI_IMAGE_BASE_URL=https://mirror.xinshu.ai
TAVERN_OPENAI_IMAGE_MODEL=gpt-image-1
TAVERN_OPENAI_IMAGE_SIZE=1024x1536
TAVERN_MEDIA_TIMEOUT_SECONDS=300
TAVERN_FORCE_PLACEHOLDER_MEDIA=false
TAVERN_JIMENG_VIDEO_MODEL=jimeng-video
TAVERN_JIMENG_BASE_URL=https://visual.volcengineapi.com
TAVERN_JIMENG_REQ_KEY=jimeng_t2v_v30
TAVERN_JIMENG_SUBMIT_ACTION=CVSync2AsyncSubmitTask
TAVERN_JIMENG_RESULT_ACTION=CVSync2AsyncGetResult
TAVERN_JIMENG_API_VERSION=2022-08-31
TAVERN_JIMENG_FPS=24
TAVERN_JIMENG_ALLOWED_DURATIONS=5,10
TAVERN_JIMENG_POLL_INTERVAL_SECONDS=2
TAVERN_JIMENG_MAX_POLL_ATTEMPTS=300
TAVERN_JIMENG_API_KEY=
TAVERN_JIMENG_ACCESS_KEY=
TAVERN_JIMENG_SECRET_KEY=
TAVERN_JIMENG_REGION=cn-north-1
TAVERN_JIMENG_SERVICE=cv
TAVERN_CORS_ORIGINS=*
DATABASE_URL=postgresql://tavern:tavern@postgres:5432/tavern
REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://tavern:tavern@rabbitmq:5672/
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=tavern
MINIO_SECRET_KEY=tavern-secret
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8770
TAVERN_API_BASE_INTERNAL=http://api:8770
N8N_IMAGE_TAG=latest
N8N_LISTEN_ADDRESS=0.0.0.0
N8N_HOST=127.0.0.1
N8N_HOST_PORT=5678
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://127.0.0.1:5678/
N8N_WEBHOOK_URL=http://127.0.0.1:5678/
N8N_ENCRYPTION_KEY=tavern-local-dev-change-me
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=tavern
N8N_BASIC_AUTH_PASSWORD=tavern-n8n-local
N8N_DIAGNOSTICS_ENABLED=false
N8N_PERSONALIZATION_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=false
N8N_SECURE_COOKIE=false
GENERIC_TIMEZONE=Asia/Shanghai
TZ=Asia/Shanghai
POSTGRES_DB=tavern
POSTGRES_USER=tavern
POSTGRES_PASSWORD=tavern
RABBITMQ_DEFAULT_USER=tavern
RABBITMQ_DEFAULT_PASS=tavern
MINIO_ROOT_USER=tavern
MINIO_ROOT_PASSWORD=tavern-secret
